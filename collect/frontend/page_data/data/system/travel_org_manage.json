{
  "tag": "layout-fit",
  "className": "padding10 h100 overflow-auto",
  "initStore": {
    "agencyDialogVisible": false,
    "agencyOp": "add",
    "relationDialogVisible": false,
    "relationOp": "add",
    "passwordDialogVisible": false,
    "agencySelection": [],
    "relationSelection": [],
    "agencySearchForm": {
      "page": 1,
      "size": 50,
      "search": ""
    },
    "relationSearchForm": {
      "page": 1,
      "size": 20,
      "search": ""
    },
    "agencyForm": {
      "biz_type": "travel",
      "checkin_status": "pending",
      "status": "normal"
    },
    "relationForm": {
      "username": "",
      "nick": "",
      "password": "",
      "phone": "",
      "role_type": "sales",
      "supervisor_user_id": "",
      "status": "normal"
    },
    "passwordForm": {
      "password": ""
    },
    "agencyList": [],
    "agencyCount": 0,
    "currentAgency": {},
    "relationList": [],
    "relationCount": 0,
    "userList": [],
    "supervisorList": []
  },
  "initAction": [
    {
      "tag": "ajax",
      "group": "agencyList",
      "api": "post:/template_data/data?service=hrm.travel_agency_list",
      "appendFields": "${agencySearchForm}",
      "appendFormFields": "agency-search-form",
      "adapt": {
        "agencyList": "${data}",
        "agencyCount": "${count}"
      }
    },
    {
      "tag": "ajax",
      "group": "userList",
      "api": "post:/template_data/data?service=hrm.user_list",
      "data": {
        "pagination": false,
        "count": false,
        "size": 500
      },
      "adapt": {
        "userList": "${data}"
      }
    }
  ],
  "children": [
    {
      "tag": "panel-group",
      "direction": "horizontal",
      "className": "h100",
      "style": {
        "height": "100%"
      },
      "children": [
        {
          "tag": "panel",
          "id": "left_agency_panel",
          "defaultSize": 24,
          "minSize": 24,
          "className": "h100 padding-right10",
          "children": [
            {
              "tag": "layout-fit",
              "className": "h100",
              "title": "旅行社列表",
              "topRight": [
                {
                  "tag": "button",
                  "type": "primary",
                  "size": "small",
                  "icon": "PlusOutlined",
                  "title": "新增旅行社",
                  "children": "新增",
                  "action": [
                    {
                      "tag": "update-store",
                      "value": {
                        "agencyDialogVisible": true,
                        "agencyOp": "add"
                      }
                    },
                    {
                      "tag": "reset-form",
                      "formName": "agencyForm"
                    }
                  ]
                },
                {
                  "tag": "button",
                  "icon": "EditOutlined",
                  "size": "small",
                  "title": "编辑旅行社",
                  "children": "编辑",
                  "disabled": "${agencySelection.length != 1}",
                  "action": [
                    {
                      "tag": "update-store",
                      "value": {
                        "agencyDialogVisible": true,
                        "agencyOp": "edit"
                      }
                    },
                    {
                      "tag": "reset-form",
                      "formName": "agencyForm"
                    },
                    {
                      "tag": "update-form",
                      "formName": "agencyForm",
                      "value": "${agencySelection[0]}"
                    }
                  ]
                },
                {
                  "tag": "button",
                  "icon": "DeleteOutlined",
                  "size": "small",
                  "title": "删除旅行社",
                  "children": "删除",
                  "danger": true,
                  "disabled": "${agencySelection.length <= 0}",
                  "confirm": {
                    "title": "确认删除吗？",
                    "description": "${'确认删除'+agencySelection.length+'条旅行社记录吗？'}"
                  },
                  "action": [
                    {
                      "tag": "ajax",
                      "api": "post:/template_data/data?service=hrm.travel_agency_delete",
                      "data": {
                        "agency_id_list": "${agencySelection.map(item=>item.agency_id)}"
                      }
                    },
                    {
                      "tag": "reload-init-action",
                      "group": "agencyList"
                    }
                  ]
                }
              ],
              "searchToolBar": [
                {
                  "tag": "form",
                  "name": "agency-search-form",
                
                  "style": {
                    "width": "100%"
                  },
                  "children": [
                    {
                      "tag": "form-item",
                      "name": "search",
                      "label": "旅行社搜索",
                      "style": {
                        "width": "100%",
                        "marginBottom": "8px"
                      },
                      "children": [
                        {
                          "tag": "input",
                          "isSearch": true,
                          "allowClear": true,
                          "style": {
                            "width": "100%"
                          },
                          "placeholder": "旅行社名称/编码",
                          "onSearchAction": [
                            {
                              "tag": "update-store",
                              "value": {
                                "agencySearchForm.page": 1
                              }
                            },
                            {
                              "tag": "reload-init-action",
                              "group": "agencyList"
                            }
                          ],
                          "action": [
                            {
                              "tag": "update-store",
                              "trigger": "onChange",
                              "value": {
                                "agencySearchForm.search": "${value}",
                                "agencySearchForm.page": 1
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ],
              "bottomToolBar": [
                {
                  "tag": "pagination",
                  "showSizeChanger": true,
                  "align": "end",
                  "pageSize": "${agencySearchForm.size}",
                  "current": "${agencySearchForm.page}",
                  "total": "${agencyCount}",
                  "action": [
                    {
                      "tag": "reload-init-action",
                      "group": "agencyList"
                    }
                  ],
                  "showTotal": true
                }
              ],
              "children": [
                {
                  "tag": "listview",
                  "keyField": "agency_id",
                  "itemData": "${agencyList}",
                  "rowClickAction": [
                    {
                      "tag": "update-store",
                      "value": {
                        "currentAgency": "${row}",
                        "agencySelection": "${[row]}",
                        "relationSelection": [],
                        "relationSearchForm": {
                          "page": 1,
                          "size": 20,
                          "search": ""
                        }
                      }
                    },
                    {
                      "tag": "reload-init-action",
                      "group": "relationList"
                    },
                    {
                      "tag": "reload-init-action",
                      "group": "supervisorList"
                    }
                  ],
                  "itemAttr": {
                    "tag": "card",
                    "size": "small",
                    "className": "cursor-pointer",
                    "style": {
                      "display": "block",
                      "width": "100%",
                      "margin": "0 0 6px 0",
                      "borderRadius": "12px",
                      "border": "${currentAgency.agency_id===row.agency_id?'1px solid #1677ff':'1px solid #f0f0f0'}",
                      "boxShadow": "${currentAgency.agency_id===row.agency_id?'0 8px 20px rgba(22,119,255,0.16)':'0 4px 14px rgba(15,23,42,0.08)'}",
                      "background": "${currentAgency.agency_id===row.agency_id?'linear-gradient(135deg,#eef6ff 0%,#ffffff 100%)':'#ffffff'}"
                    },
                    "bodyStyle": {
                      "padding": "11px 12px"
                    },
                    "hoverable": true,
                    "children": [
                      {
                        "tag": "row",
                        "style": {
                          "alignItems": "center"
                        },
                        "children": [
                          {
                            "tag": "col",
                            "span": 4,
                            "style": {
                              "display": "flex",
                              "justifyContent": "center"
                            },
                            "children": [
                              {
                                "tag": "attachment-show",
                                "visible": "${!!row.logo_path}",
                                "path": "${row.logo_path}",
                                "width": 36,
                                "height": 36,
                                "style": {
                                  "borderRadius": "50%",
                                  "overflow": "hidden",
                                  "border": "1px solid #dbeafe"
                                }
                              },
                              {
                                "tag": "div",
                                "visible": "${!row.logo_path}",
                                "style": {
                                  "width": "36px",
                                  "height": "36px",
                                  "borderRadius": "50%",
                                  "display": "flex",
                                  "alignItems": "center",
                                  "justifyContent": "center",
                                  "background": "${currentAgency.agency_id===row.agency_id?'#1677ff':'#e6f4ff'}",
                                  "color": "${currentAgency.agency_id===row.agency_id?'#ffffff':'#1677ff'}",
                                  "fontSize": "14px",
                                  "fontWeight": 700
                                },
                                "children": "${(row.agency_name||'旅').slice(0,1)}"
                              }
                            ]
                          },
                          {
                            "tag": "col",
                            "span": 20,
                            "style": {
                              "minWidth": 0
                            },
                            "children": [
                              {
                                "tag": "div",
                                "style": {
                                  "fontSize": "14px",
                                  "lineHeight": "22px",
                                  "fontWeight": 600,
                                  "color": "#1f2937",
                                  "whiteSpace": "nowrap",
                                  "overflow": "hidden",
                                  "textOverflow": "ellipsis"
                                },
                                "children": "${row.agency_name+' · '+(row.agency_code||'-')}"
                              },
                              {
                                "tag": "div",
                                "style": {
                                  "fontSize": "13px",
                                  "lineHeight": "20px",
                                  "color": "#6b7280",
                                  "display": "flex",
                                  "alignItems": "center",
                                  "gap": "8px",
                                  "whiteSpace": "nowrap",
                                  "overflow": "hidden",
                                  "textOverflow": "ellipsis"
                                },
                                "children": [
                                  {
                                    "tag": "icon",
                                    "icon": "${(row.checkin_status||'pending')==='active'?'CheckCircleFilled':'ClockCircleFilled'}",
                                    "style": {
                                      "fontSize": "12px",
                                      "color": "${(row.checkin_status||'pending')==='active'?'#16a34a':'#f59e0b'}"
                                    }
                                  },
                                  {
                                    "tag": "span",
                                    "children": "${(row.checkin_status||'pending')==='active'?'已入住':'待入住'}"
                                  },
                                  {
                                    "tag": "span",
                                    "style": {
                                      "padding": "1px 8px",
                                      "borderRadius": "10px",
                                      "background": "#f0f7ff",
                                      "color": "#1d4ed8",
                                      "fontWeight": 600
                                    },
                                    "children": "${'主管 '+(row.supervisor_count||0)}"
                                  },
                                  {
                                    "tag": "span",
                                    "style": {
                                      "padding": "1px 8px",
                                      "borderRadius": "10px",
                                      "background": "#fff7ed",
                                      "color": "#c2410c",
                                      "fontWeight": 600
                                    },
                                    "children": "${'销售 '+(row.sales_count||0)}"
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "tag": "panel-resize",
          "style": {
            "width": "8px",
            "backgroundColor": "#f2f3f5",
            "cursor": "col-resize"
          }
        },
        {
          "tag": "panel",
          "id": "right_relation_panel",
          "defaultSize": 76,
          "minSize": 35,
          "className": "h100 padding-left10",
          "children": [
            {
              "tag": "div",
              "visible": "${!currentAgency.agency_id}",
              "style": {
                "height": "100%",
                "display": "flex",
                "alignItems": "center",
                "justifyContent": "center",
                "padding": "18px 8px"
              },
              "children": [
                {
                  "tag": "div",
                  "style": {
                    "width": "min(920px, 96%)",
                    "background": "linear-gradient(180deg,#f8fbff 0%,#ffffff 52%)",
                    "border": "1px solid #dbeafe",
                    "borderRadius": "16px",
                    "boxShadow": "0 18px 38px rgba(30,64,175,0.10)",
                    "padding": "22px"
                  },
                  "children": [
                    {
                      "tag": "div",
                      "style": {
                        "fontSize": "22px",
                        "fontWeight": 700,
                        "color": "#1e3a8a",
                        "lineHeight": "32px",
                        "marginBottom": "6px"
                      },
                      "children": "请选择左侧旅行社开始组织管理"
                    },
                    {
                      "tag": "div",
                      "style": {
                        "fontSize": "14px",
                        "color": "#475569",
                        "lineHeight": "22px",
                        "marginBottom": "16px"
                      },
                      "children": "选中旅行社后，可管理成员、新增销售/主管并维护直属关系。未创建旅行社时可先快捷新增。"
                    },
                    {
                      "tag": "row",
                      "gutter": 12,
                      "style": {
                        "marginBottom": "16px"
                      },
                      "children": [
                        {
                          "tag": "col",
                          "span": 8,
                          "children": [
                            {
                              "tag": "card",
                              "size": "small",
                              "style": {
                                "borderRadius": "12px",
                                "background": "#ffffff",
                                "border": "1px solid #e2e8f0"
                              },
                              "bodyStyle": {
                                "padding": "14px"
                              },
                              "children": [
                                {
                                  "tag": "div",
                                  "style": {
                                    "fontWeight": 600,
                                    "color": "#0f172a",
                                    "marginBottom": "6px"
                                  },
                                  "children": "成员管理"
                                },
                                {
                                  "tag": "div",
                                  "style": {
                                    "fontSize": "13px",
                                    "color": "#64748b",
                                    "lineHeight": "20px"
                                  },
                                  "children": "新增、编辑、删除组织成员，维护账号信息。"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "tag": "col",
                          "span": 8,
                          "children": [
                            {
                              "tag": "card",
                              "size": "small",
                              "style": {
                                "borderRadius": "12px",
                                "background": "#ffffff",
                                "border": "1px solid #e2e8f0"
                              },
                              "bodyStyle": {
                                "padding": "14px"
                              },
                              "children": [
                                {
                                  "tag": "div",
                                  "style": {
                                    "fontWeight": 600,
                                    "color": "#0f172a",
                                    "marginBottom": "6px"
                                  },
                                  "children": "角色关系"
                                },
                                {
                                  "tag": "div",
                                  "style": {
                                    "fontSize": "13px",
                                    "color": "#64748b",
                                    "lineHeight": "20px"
                                  },
                                  "children": "主管可直接归属旅行社，销售需绑定直属主管。"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "tag": "col",
                          "span": 8,
                          "children": [
                            {
                              "tag": "card",
                              "size": "small",
                              "style": {
                                "borderRadius": "12px",
                                "background": "#ffffff",
                                "border": "1px solid #e2e8f0"
                              },
                              "bodyStyle": {
                                "padding": "14px"
                              },
                              "children": [
                                {
                                  "tag": "div",
                                  "style": {
                                    "fontWeight": 600,
                                    "color": "#0f172a",
                                    "marginBottom": "6px"
                                  },
                                  "children": "快速操作"
                                },
                                {
                                  "tag": "div",
                                  "style": {
                                    "fontSize": "13px",
                                    "color": "#64748b",
                                    "lineHeight": "20px"
                                  },
                                  "children": "支持按姓名/账号搜索成员，并可按分页浏览。"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "tag": "div",
                      "style": {
                        "display": "flex",
                        "gap": "10px",
                        "alignItems": "center",
                        "marginBottom": "10px"
                      },
                      "children": [
                        {
                          "tag": "button",
                          "type": "primary",
                          "icon": "PlusOutlined",
                          "children": "快捷新增旅行社",
                          "action": [
                            {
                              "tag": "update-store",
                              "value": {
                                "agencyDialogVisible": true,
                                "agencyOp": "add"
                              }
                            },
                            {
                              "tag": "reset-form",
                              "formName": "agencyForm"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "tag": "div",
                      "style": {
                        "background": "#f8fafc",
                        "border": "1px dashed #cbd5e1",
                        "borderRadius": "10px",
                        "padding": "12px 14px",
                        "fontSize": "13px",
                        "lineHeight": "22px",
                        "color": "#334155"
                      },
                      "children": "使用建议：先新增旅行社并在左侧选中，再新增组织成员；若成员角色为销售，需在表单中选择直属主管。"
                    }
                  ]
                }
              ]
            },
            {
              "tag": "layout-fit",
              "visible": "${!!currentAgency.agency_id}",
              "className": "h100",
              "title": "组织关系",
              "topRight": [
                {
                  "tag": "button",
                  "type": "primary",
                  "icon": "PlusOutlined",
                  "size": "small",
                  "title": "新增组织成员",
                  "children": "新增",
                  "visible": "${!!currentAgency.agency_id}",
                  "disabled": "${!currentAgency.agency_id}",
                  "action": [
                    {
                      "tag": "update-store",
                      "value": {
                        "relationDialogVisible": true,
                        "relationOp": "add"
                      }
                    },
                    {
                      "tag": "reset-form",
                      "formName": "relationForm"
                    }
                  ]
                },
                {
                  "tag": "button",
                  "icon": "EditOutlined",
                  "size": "small",
                  "title": "编辑组织成员",
                  "children": "编辑",
                  "visible": "${!!currentAgency.agency_id}",
                  "disabled": "${relationSelection.length != 1}",
                  "action": [
                    {
                      "tag": "update-store",
                      "value": {
                        "relationDialogVisible": true,
                        "relationOp": "edit"
                      }
                    },
                    {
                      "tag": "reset-form",
                      "formName": "relationForm"
                    },
                    {
                      "tag": "update-form",
                      "formName": "relationForm",
                      "value": "${relationSelection[0]}"
                    }
                  ]
                },
                {
                  "tag": "button",
                  "icon": "LockOutlined",
                  "size": "small",
                  "title": "修改密码",
                  "children": "改密",
                  "visible": "${!!currentAgency.agency_id}",
                  "disabled": "${relationSelection.length != 1}",
                  "action": [
                    {
                      "tag": "reset-form",
                      "formName": "passwordForm"
                    },
                    {
                      "tag": "update-store",
                      "value": {
                        "passwordDialogVisible": true
                      }
                    }
                  ]
                },
                {
                  "tag": "button",
                  "icon": "DeleteOutlined",
                  "size": "small",
                  "title": "删除组织成员",
                  "children": "删除",
                  "danger": true,
                  "visible": "${!!currentAgency.agency_id}",
                  "disabled": "${relationSelection.length <= 0}",
                  "confirm": {
                    "title": "确认删除吗？",
                    "description": "${'确认删除'+relationSelection.length+'条关系吗？'}"
                  },
                  "action": [
                    {
                      "tag": "ajax",
                      "api": "post:/template_data/data?service=hrm.travel_org_user_delete",
                      "data": {
                        "relation_id_list": "${relationSelection.map(item=>item.relation_id)}"
                      }
                    },
                    {
                      "tag": "reload-init-action",
                      "group": "relationList"
                    },
                    {
                      "tag": "reload-init-action",
                      "group": "supervisorList"
                    }
                  ]
                }
              ],
              "searchToolBar": [
                {
                  "tag": "form",
                  "name": "relation-search-form",
                  "visible": "${!!currentAgency.agency_id}",
                  "style": {
                    "width": "100%"
                  },
                  "children": [
                    {
                      "tag": "form-item",
                      "name": "search",
                      "label": "成员搜索",
                      "style": {
                        "width": "100%",
                        "marginBottom": "8px"
                      },
                      "children": [
                        {
                          "tag": "input",
                          "isSearch": true,
                          "allowClear": true,
                          "style": {
                            "width": "100%"
                          },
                          "placeholder": "主管/销售姓名或登录名",
                          "onSearchAction": [
                            {
                              "tag": "update-store",
                              "value": {
                                "relationSearchForm.page": 1
                              }
                            },
                            {
                              "tag": "reload-init-action",
                              "group": "relationList"
                            }
                          ],
                          "action": [
                            {
                              "tag": "update-store",
                              "trigger": "onChange",
                              "value": {
                                "relationSearchForm.search": "${value}",
                                "relationSearchForm.page": 1
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ],
              "bottomToolBar": [
                {
                  "tag": "pagination",
                  "visible": "${!!currentAgency.agency_id}",
                  "showSizeChanger": true,
                  "align": "end",
                  "pageSize": "${relationSearchForm.size}",
                  "current": "${relationSearchForm.page}",
                  "total": "${relationCount}",
                  "action": [
                    {
                      "tag": "reload-init-action",
                      "group": "relationList"
                    }
                  ],
                  "showTotal": true
                }
              ],
              "children": [
                {
                  "tag": "table",
                  "selection": "${relationSelection}",
                  "rowSelection": "multiple",
                  "columnDefs": [
                    {
                      "headerName": "#",
                      "width": 60,
                      "valueGetter": "node.rowIndex + 1",
                      "sortable": false,
                      "pinned": "left"
                    },
                    {
                      "pinned": "left",
                      "checkboxSelection": true,
                      "headerCheckboxSelection": true,
                      "headerName": "登录名",
                      "field": "username"
                    },
                    {
                      "headerName": "姓名",
                      "field": "nick"
                    },
                    {
                      "headerName": "角色",
                      "field": "role_type",
                      "valueFormatter": "${params.value==='supervisor'?'主管':'销售'}"
                    },
                    {
                      "headerName": "直属主管",
                      "field": "supervisor_name"
                    },
                    {
                      "headerName": "手机号",
                      "field": "phone"
                    },
                    {
                      "headerName": "创建时间",
                      "field": "create_time"
                    }
                  ],
                  "rowData": "${relationList}"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "tag": "dialog",
      "title": "${agencyOp=='add'?'新增旅行社':'编辑旅行社'}",
      "open": "${agencyDialogVisible}",
      "action": [
        {
          "tag": "submit-form",
          "formName": "agencyForm"
        },
        {
          "tag": "ajax",
          "enable": "${agencyOp=='add'}",
          "api": "post:/template_data/data?service=hrm.travel_agency_save",
          "appendFormFields": "agencyForm"
        },
        {
          "tag": "ajax",
          "enable": "${agencyOp=='edit'}",
          "api": "post:/template_data/data?service=hrm.travel_agency_update",
          "appendFormFields": "agencyForm",
          "data": {
            "agency_id": "${agencySelection[0].agency_id}"
          }
        },
        {
          "tag": "update-store",
          "value": {
            "agencyDialogVisible": false
          }
        },
        {
          "tag": "reload-init-action",
          "group": "agencyList"
        }
      ],
      "children": [
        {
          "tag": "form",
          "name": "agencyForm",
          "initialValues": "${agencyForm}",
          "labelCol": {
            "span": 6
          },
          "children": [
            {
              "tag": "form-item",
              "name": "agency_name",
              "label": "旅行社名称",
              "rules": [
                {
                  "required": true,
                  "message": "请输入旅行社名称"
                }
              ],
              "children": [
                {
                  "tag": "input",
                  "placeholder": "请输入旅行社名称"
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "agency_code",
              "label": "旅行社编码",
              "rules": [
                {
                  "required": true,
                  "message": "请输入旅行社编码"
                }
              ],
              "children": [
                {
                  "tag": "input",
                  "placeholder": "请输入旅行社编码"
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "logo_path",
              "label": "旅行社图片",
              "children": [
                {
                  "tag": "attachment",
                  "placeholder": "请上传旅行社图片",
                  "attachment_prop": {
                    "width": 72,
                    "height": 72,
                    "style": {
                      "marginTop": "6px",
                      "borderRadius": "8px",
                      "overflow": "hidden"
                    }
                  },
                  "uploadConfig": {
                    "showUploadList": false,
                    "api": "post:/template_data/data?service=sport.upload_course_attachment",
                    "data": {
                      "type": "attachment",
                      "only_path": false
                    }
                  },
                  "finish_action": [
                    {
                      "tag": "update-form",
                      "formName": "agencyForm",
                      "value": {
                        "logo_path": "${row.data.path}"
                      }
                    }
                  ]
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "checkin_status",
              "label": "入住状态",
              "children": [
                {
                  "tag": "select",
                  "options": [
                    {
                      "value": "pending",
                      "label": "待入住"
                    },
                    {
                      "value": "active",
                      "label": "已入住"
                    }
                  ]
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "description",
              "label": "备注",
              "children": [
                {
                  "tag": "input",
                  "placeholder": "可填写旅行社组织说明"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "tag": "dialog",
      "title": "修改成员密码",
      "open": "${passwordDialogVisible}",
      "action": [
        {
          "tag": "submit-form",
          "formName": "passwordForm"
        },
        {
          "tag": "ajax",
          "api": "post:/template_data/data?service=hrm.update_user_by_username",
          "appendFormFields": "passwordForm",
          "data": {
            "username": "${relationSelection.length>0?relationSelection[0].username:''}"
          }
        },
        {
          "tag": "update-store",
          "value": {
            "passwordDialogVisible": false
          }
        },
        {
          "tag": "reset-form",
          "formName": "passwordForm"
        }
      ],
      "children": [
        {
          "tag": "form",
          "name": "passwordForm",
          "initialValues": "${passwordForm}",
          "labelCol": {
            "span": 6
          },
          "children": [
            {
              "tag": "form-item",
              "label": "当前成员",
              "children": [
                {
                  "tag": "div",
                  "children": "${relationSelection.length>0?(relationSelection[0].nick+'（'+relationSelection[0].username+'）'):'-'}"
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "password",
              "label": "新密码",
              "rules": [
                {
                  "required": true,
                  "message": "请输入新密码"
                }
              ],
              "children": [
                {
                  "tag": "input",
                  "showPassword": true,
                  "placeholder": "请输入新密码"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "tag": "dialog",
      "title": "${relationOp=='add'?'新增组织成员':'编辑组织成员'}",
      "open": "${relationDialogVisible}",
      "confirmAndContinue": "${relationOp=='add'}",
      "action": [
        {
          "tag": "submit-form",
          "formName": "relationForm"
        },
        {
          "tag": "ajax",
          "enable": "${relationOp=='add'}",
          "api": "post:/template_data/data?service=hrm.travel_org_user_save",
          "appendFormFields": "relationForm",
          "data": {
            "agency_id": "${currentAgency.agency_id}"
          }
        },
        {
          "tag": "ajax",
          "enable": "${relationOp=='edit'}",
          "api": "post:/template_data/data?service=hrm.update_user_by_user_id",
          "appendFormFields": "relationForm",
          "data": {
            "user_id": "${relationSelection.length>0?relationSelection[0].user_id:''}"
          }
        },
        {
          "tag": "ajax",
          "enable": "${relationOp=='edit'}",
          "api": "post:/template_data/data?service=hrm.travel_org_user_update",
          "appendFormFields": "relationForm",
          "data": {
            "relation_id": "${relationSelection.length>0?relationSelection[0].relation_id:''}",
            "agency_id": "${currentAgency.agency_id}",
            "user_id": "${relationSelection.length>0?relationSelection[0].user_id:''}"
          }
        },
        {
          "tag": "reload-init-action",
          "group": "relationList"
        },
        {
          "tag": "reload-init-action",
          "group": "supervisorList"
        },
        {
          "tag": "reset-form",
          "enable": "${relationOp=='add' && confirmAndContinue}",
          "formName": "relationForm"
        },
        {
          "tag": "update-store",
          "enable": "${!confirmAndContinue}",
          "value": {
            "relationDialogVisible": false
          }
        }
      ],
      "children": [
        {
          "tag": "form",
          "name": "relationForm",
          "initialValues": "${relationForm}",
          "labelCol": {
            "span": 6
          },
          "children": [
            {
              "tag": "form-item",
              "name": "username",
              "label": "用户名",
              "rules": [
                {
                  "required": true,
                  "message": "请输入用户名"
                }
              ],
              "children": [
                {
                  "tag": "input",
                  "placeholder": "请输入登录用户名"
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "nick",
              "label": "姓名",
              "rules": [
                {
                  "required": true,
                  "message": "请输入姓名"
                }
              ],
              "children": [
                {
                  "tag": "input",
                  "placeholder": "请输入姓名"
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "password",
              "label": "密码",
              "visible": "${relationOp==='add'}",
              "rules": [
                {
                  "required": true,
                  "message": "请输入密码"
                }
              ],
              "children": [
                {
                  "tag": "input",
                  "type": "password",
                  "placeholder": "请输入初始密码"
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "phone",
              "label": "手机号",
              "children": [
                {
                  "tag": "input",
                  "placeholder": "请输入手机号"
                }
              ]
            },
            {
              "tag": "form-item",
              "label": "当前成员",
              "visible": "${relationOp==='edit'}",
              "children": [
                {
                  "tag": "div",
                  "children": "${relationSelection.length>0?(relationSelection[0].nick+'（'+relationSelection[0].username+'）'):'-'}"
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "role_type",
              "label": "组织角色",
              "rules": [
                {
                  "required": true,
                  "message": "请选择角色"
                }
              ],
              "children": [
                {
                  "tag": "select",
                  "options": [
                    {
                      "value": "supervisor",
                      "label": "主管"
                    },
                    {
                      "value": "sales",
                      "label": "销售"
                    }
                  ]
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "supervisor_user_id",
              "label": "直属主管",
              "visible": "${getFormValue('relationForm','role_type')=='sales'}",
              "children": [
                {
                  "tag": "select",
                  "fieldNames": {
                    "label": "nick",
                    "value": "user_id"
                  },
                  "optionRender": "${row.nick+'（'+row.username+'）'}",
                  "options": "${supervisorList}",
                  "placeholder": "销售必须选择直属主管"
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "description",
              "label": "备注",
              "children": [
                {
                  "tag": "input",
                  "isTextarea": true,
                  "rows": 3,
                  "placeholder": "可填写组织说明"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "actionGroupDefine": {
    "relationList": [
      {
        "tag": "ajax",
        "enable": "${currentAgency.agency_id}",
        "group": "relationList",
        "api": "post:/template_data/data?service=hrm.travel_org_user_list",
        "appendFields": "${relationSearchForm}",
        "appendFormFields": "relation-search-form",
        "data": {
          "agency_id": "${currentAgency.agency_id}"
        },
        "adapt": {
          "relationList": "${data}",
          "relationCount": "${count}"
        }
      }
    ],
    "supervisorList": [
      {
        "tag": "ajax",
        "enable": "${currentAgency.agency_id}",
        "group": "supervisorList",
        "api": "post:/template_data/data?service=hrm.travel_org_user_list",
        "data": {
          "agency_id": "${currentAgency.agency_id}",
          "role_type": "supervisor",
          "pagination": false,
          "count": false
        },
        "adapt": {
          "supervisorList": "${data}"
        }
      }
    ]
  }
}
