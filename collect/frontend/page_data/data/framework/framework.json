{
  "tag": "app",
  "children": [
    {
      "tag": "css",
      "src": "/data/index.css"
    },
    {
      "tag": "layout",

      "children": [
        {
          "tag": "header",
          "children": [
            {
              "tag": "label",
              "style": {
                "fontSize": "20px",
                "fontWeight": "bold",
                "color": "#fff",
                "paddingRight":"20px"
              },
              "children": "collect"
            },
            {
              "tag": "menu",
              "visible": "${menuShow==='top'}",
              "theme": "dark",
              "mode": "horizontal",
              "changeRouter": true,
              "rule": {
                "key_field": "menu_code",
                "label_field": "menu_name",
                "icon_field": "icon",
                "to_field": "url"
              },
              "style": {
                "backgroundColor": "inherit",
                "flex": 1
              },

              "items": "${menu_list.filter((item)=>item.in_menu!=='0')}"
            },
            {
              "tag": "layout-fit",
              "initStore": {
                "user": {}
              },
              "initAction": [
                {
                  "tag": "ajax",
                  "api": "post:/template_data/data?service=system.current_user",
                  "adapt": {
                    "user": "${data}"
                  }
                }
              ],
              "children": [
                {
                  "tag": "dropdown",
                  "menu": {
                    "items": [
                      {
                        "label": "注销",
                        "code": "logout"
                      }
                    ]
                  },
                  "action": [
                    {
                      "tag": "ajax",
                      "enable": "${code=='logout'}",
                      "api": "post:/template_data/data?service=system.logout"
                    },
                    {
                      "tag": "redirect",
                      "url": "/collect-ui/#/collect-ui/login"
                    }
                  ],
                  "arrow": true,
                  "children": [
                    "${user.nick||user.username||'未登录'}",
                    {
                      "tag": "icon",
                      "style": {
                        "marginLeft": 10
                      },
                      "icon": "DownOutlined"
                    }
                  ]
                }
              ]
            }
          ],
          "style": {
            "color": "#fff",
            "height": 44,
            "paddingInline": 48,
            "lineHeight": "44px",
            "backgroundColor": "#4096ff",
            "padding": "0 20px",
            "display": "flex"
          }
        },
        {
          "tag": "layout",
          "children": [
            {
              "tag": "sider",
              "visible": "${menuShow==='left'}",
              "width": "240px",
              "collapsible": true,
              "collapsedWidth": "40",
              "children": [
                {
                  "tag": "form",
                  "name": "framework-form",
                  "children": [
                    {
                      "tag": "form-item",
                      "name": "menu",
                      "children": [
                        {
                          "tag": "menu",
                          "mode": "inline",
                          "theme": "dark",
                          "changeRouter": true,
                          "rule": {
                            "key_field": "menu_code",
                            "label_field": "menu_name",
                            "icon_field": "icon",
                            "to_field": "url"
                          },
                          "defaultOpenKeys": [
                            "home",
                            "dashboard",
                            "sub1"
                          ],
                          "items": "${menu_list.filter((item)=>item.in_menu!==false)}"
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "tag": "content",
              "style": {
                "display": "flex",
                "flexDirection": "column",
                "overflow": "hidden"
              },
              "children": [
                {
                  "tag": "router-tab",
                  "theme": "dark",
                  "className": "dark-theme-tabs"
                },
                {
                  "tag": "outlet",
                  "style": {
                    "flex": 1,
                    "overflow": "hidden"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
