{
  "url": "https://api.deepseek.com/v1/chat/completions",
  "method": "POST",
  "header": {
    "Content-Type": "application/json",
    "Authorization": "Bearer {{get_key `deepseek_api_key`}}"
  },
  "timeout": 600,
  "result_json": true,
  "data": {
    "model": "deepseek-v4-flash",
    "messages": [
      {
        "role": "system",
        "content": "[system_prompt]"
      },
      {
        "role": "user",
        "content": "[prompt_content]"
      }
    ],
    "temperature": 0.3
  }
}
