{
  "url": "{{get_key `to_text_base_url`}}/tencent/account-requests",
  "method": "GET",
  "header": {
    "X-Admin-Token": "{{get_key `to_text_admin_token`}}"
  },
  "result_json": true,
  "data": {
    "status": "[status]",
    "account_name": "[account_name_query]",
    "match_mode": "[match_mode]"
  }
}
