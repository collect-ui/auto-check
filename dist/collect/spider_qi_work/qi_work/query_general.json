{
  "url": "https://api.qi.work/upm/general/queryGeneral",
  "method": "POST",
  "header": {
    "Content-Type": "application/json",
    "Accept": "application/json, text/plain, */*",
    "Authorization": "Bearer {{.authorization}}",
    "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36"
  },
  "result_json": true,
  "data": {
    "companyId": "[companyId]",
    "controlId": "[controlId]",
    "loginUserId": "[loginUserId]",
    "createDepartmentId": "[createDepartmentId]",
    "pageSize": "[pageSize]",
    "pageNum": "[pageNum]",
    "appKey": "[appKey]",
    "sortField": "[sortField]",
    "sortOrder": "[sortOrder]",
    "fieldsStr": [
      "phoneId",
      "name",
      "phoneOutNumber",
      "relegation",
      "phoneOperator",
      "phoneCallType",
      "phoneClientType",
      "ringTimeLength",
      "phoneRingTime",
      "phoneEndTime",
      "phoneStatus",
      "callTimeLength",
      "phoneRecordAddress",
      "phoneStartTime",
      "groupId",
      "userId",
      "phoneInNumber",
      "phoneType",
      "uid"
    ],
    "extraFieldsStr": [
      {
        "appKey": "customer",
        "relationField": [
          "phoneOutNumber",
          "mobile"
        ],
        "fields": [
          "name"
        ]
      },
      {
        "appKey": "team",
        "relationField": [
          "userId",
          "userId"
        ],
        "fields": [
          "groupId"
        ]
      }
    ],
    "queryParams": {
        "relation": "and",
        "children": [
            {
                "type": "one",
                "query": {
                    "field": "phoneStartTime",
                    "condition": "between",
                    "value": [
                        "[startTime]",
                        "[endTime]"
                    ]
                }
            }
        ]
    },
    "viewDataRangeType": "[viewDataRangeType]"
  }
}
