{
  "tag": "layout-fit",
  "className": "padding10 h100 overflow-auto",
  "title": "销售客服维护",
  "initStore": {
    "dialogVisible": false,
    "op": "add",
    "selection": [],
    "searchForm": {
      "page": 1,
      "size": 20,
      "search": ""
    },
    "opForm": {
      "password": "123456",
      "status": "normal",
      "role_code": "sales"
    },
    "count": 0,
    "dataList": []
  },
  "initAction": [
    {
      "tag": "ajax",
      "group": "dataList",
      "api": "post:/template_data/data?service=hrm.sales_cs_user_list",
      "appendFormFields": "sales-cs-user-form",
      "appendFields": "${searchForm}",
      "adapt": {
        "dataList": "${data}",
        "count": "${count}"
      }
    }
  ],
  "children": [
    {
      "tag": "table",
      "selection": "${selection}",
      "rowSelection": "multiple",
      "columnDefs": [
        {
          "headerName": "#",
          "width": 60,
          "valueGetter": "node.rowIndex + 1",
          "sortable": false,
          "pinned": "left"
        },
        {
          "pinned": "left",
          "checkboxSelection": true,
          "headerCheckboxSelection": true,
          "headerName": "登录名",
          "field": "username"
        },
        {
          "headerName": "姓名",
          "field": "nick"
        },
        {
          "headerName": "手机号",
          "field": "phone"
        },
        {
          "headerName": "角色",
          "field": "role_names"
        },
        {
          "headerName": "状态",
          "field": "status_text"
        },
        {
          "headerName": "创建时间",
          "field": "create_time"
        }
      ],
      "rowData": "${dataList}"
    },
    {
      "tag": "dialog",
      "title": "${op=='add'?'新增账号':'编辑账号'}",
      "width": "45%",
      "open": "${dialogVisible}",
      "action": [
        {
          "tag": "submit-form",
          "formName": "opForm"
        },
        {
          "tag": "ajax",
          "enable": "${op=='add'}",
          "api": "post:/template_data/data?service=hrm.sales_cs_user_create",
          "appendFormFields": "opForm",
          "data": {
            "role_id_list": "${[getFormValue('opForm','role_code')]}"
          }
        },
        {
          "tag": "ajax",
          "enable": "${op=='edit'}",
          "api": "post:/template_data/data?service=hrm.sales_cs_user_update",
          "appendFormFields": "opForm",
          "data": {
            "user_id": "${selection[0].user_id}",
            "role_id_list": "${[getFormValue('opForm','role_code')]}"
          }
        },
        {
          "tag": "update-store",
          "value": {
            "dialogVisible": false
          }
        },
        {
          "tag": "reload-init-action",
          "group": "dataList"
        }
      ],
      "children": [
        {
          "tag": "form",
          "name": "opForm",
          "initialValues": "${opForm}",
          "labelCol": {
            "span": 5
          },
          "children": [
            {
              "tag": "form-item",
              "name": "username",
              "label": "登录名",
              "rules": [
                {
                  "required": true,
                  "message": "请输入登录名"
                }
              ],
              "children": [
                {
                  "tag": "input",
                  "placeholder": "请输入登录名"
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "nick",
              "label": "姓名",
              "rules": [
                {
                  "required": true,
                  "message": "请输入姓名"
                }
              ],
              "children": [
                {
                  "tag": "input",
                  "placeholder": "请输入姓名"
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "phone",
              "label": "手机号",
              "children": [
                {
                  "tag": "input",
                  "placeholder": "请输入手机号"
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "password",
              "label": "密码",
              "visible": "${op=='add'}",
              "children": [
                {
                  "tag": "input",
                  "type": "password",
                  "placeholder": "新增时输入密码，默认123456"
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "status",
              "label": "状态",
              "children": [
                {
                  "tag": "select",
                  "options": [
                    {
                      "value": "normal",
                      "label": "正常"
                    },
                    {
                      "value": "trial",
                      "label": "试用"
                    }
                  ]
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "role_code",
              "label": "角色",
              "rules": [
                {
                  "required": true,
                  "message": "请选择角色"
                }
              ],
              "children": [
                {
                  "tag": "select",
                  "options": [
                    {
                      "value": "sales",
                      "label": "销售"
                    },
                    {
                      "value": "customer_service",
                      "label": "客服"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "topRight": [
    {
      "tag": "button",
      "type": "primary",
      "children": "新增",
      "action": [
        {
          "tag": "update-store",
          "value": {
            "dialogVisible": true,
            "op": "add"
          }
        },
        {
          "tag": "reset-form",
          "formName": "opForm"
        },
        {
          "tag": "update-form",
          "formName": "opForm",
          "value": "${opForm}"
        }
      ]
    },
    {
      "tag": "button",
      "children": "编辑",
      "disabled": "${selection.length != 1}",
      "action": [
        {
          "tag": "update-store",
          "value": {
            "dialogVisible": true,
            "op": "edit"
          }
        },
        {
          "tag": "reset-form",
          "formName": "opForm"
        },
        {
          "tag": "update-form",
          "formName": "opForm",
          "value": "${selection[0]}"
        }
      ]
    },
    {
      "tag": "button",
      "children": "删除",
      "danger": true,
      "disabled": "${selection.length <= 0}",
      "confirm": {
        "title": "确认删除吗？",
        "description": "${'确认删除'+selection.length+'条记录吗？'}"
      },
      "action": [
        {
          "tag": "ajax",
          "api": "post:/template_data/data?service=hrm.sales_cs_user_delete",
          "data": {
            "user_id_list": "${selection.map(item=>item.user_id)}"
          }
        },
        {
          "tag": "reload-init-action",
          "group": "dataList"
        }
      ]
    }
  ],
  "searchToolBar": [
    {
      "tag": "form",
      "name": "sales-cs-user-form",
      "initialValues": "${searchForm}",
      "submitOnChange": true,
      "children": [
        {
          "tag": "row",
          "children": [
            {
              "tag": "col",
              "span": 6,
              "children": [
                {
                  "tag": "form-item",
                  "name": "search",
                  "label": "搜索",
                  "children": [
                    {
                      "tag": "input",
                      "placeholder": "登录名/姓名",
                      "allowClear": true
                    }
                  ]
                }
              ]
            },
            {
              "tag": "col",
              "span": 6,
              "children": [
                {
                  "tag": "button",
                  "type": "primary",
                  "children": "搜索",
                  "action": [
                    {
                      "tag": "reload-init-action",
                      "group": "dataList"
                    }
                  ]
                },
                {
                  "tag": "button",
                  "children": "重置",
                  "action": [
                    {
                      "tag": "reset-form",
                      "formName": "sales-cs-user-form"
                    },
                    {
                      "tag": "reload-init-action",
                      "group": "dataList"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "bottomToolBar": [
    {
      "tag": "pagination",
      "showSizeChanger": true,
      "align": "end",
      "pageSize": "${searchForm.size}",
      "current": "${searchForm.page}",
      "total": "${count}",
      "action": [
        {
          "tag": "reload-init-action",
          "group": "dataList"
        }
      ],
      "showTotal": true
    }
  ]
}
