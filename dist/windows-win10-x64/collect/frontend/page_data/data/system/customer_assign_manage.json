{
  "tag": "layout-fit",
  "className": "padding10 h100 overflow-auto",
  "initStore": {
    "leadDialogVisible": false,
    "assignDialogVisible": false,
    "leadOp": "add",
    "selection": [],
    "agencySelection": [],
    "currentAgency": {},
    "agencyList": [],
    "agencyCount": 0,
    "salesOptions": [],
    "routeOptions": [],
    "agencySearchForm": {
      "page": 1,
      "size": 50,
      "search": ""
    },
    "searchForm": {
      "page": 1,
      "size": 20,
      "search": "",
      "agency_id": "",
      "assign_date_range": []
    },
    "leadForm": {
      "agency_id": "",
      "customer_name": "",
      "contact": "",
      "wechat_account": "",
      "source_platform": "douyin",
      "assign_date": "${new Date().toISOString().slice(0,10)}",
      "sales_user_id": "",
      "route_id": "",
      "status": "normal",
      "description": ""
    },
    "assignForm": {
      "assign_id": "",
      "lead_id": "",
      "agency_id": "",
      "assign_date": "${new Date().toISOString().slice(0,10)}",
      "sales_user_id": "",
      "route_id": "",
      "supervisor_user_id": "",
      "description": ""
    },
    "count": 0,
    "leadList": []
  },
  "initAction": [
    {
      "tag": "ajax",
      "group": "agencyList",
      "api": "post:/template_data/data?service=hrm.travel_agency_list",
      "appendFields": "${agencySearchForm}",
      "appendFormFields": "agency-search-form",
      "adapt": {
        "agencyList": "${data}",
        "agencyCount": "${count}"
      }
    },
    {
      "tag": "update-store",
      "value": {
        "currentAgency": "${agencyList&&agencyList.length>0?agencyList[0]:{}}",
        "agencySelection": "${agencyList&&agencyList.length>0?[agencyList[0]]:[]}",
        "searchForm.agency_id": "${agencyList&&agencyList.length>0?agencyList[0].agency_id:''}",
        "searchForm.assign_date_range": []
      }
    },
    {
      "tag": "update-form",
      "formName": "lead-search-form",
      "value": {
        "assign_date_range": "${searchForm.assign_date_range}",
        "search": "${searchForm.search}"
      }
    },
    {
      "tag": "ajax",
      "group": "leadList",
      "enable": "${!!currentAgency.agency_id}",
      "api": "post:/template_data/data?service=hrm.customer_lead_list",
      "appendFields": "${searchForm}",
      "data": {
        "agency_id": "${currentAgency.agency_id||searchForm.agency_id||''}"
      },
      "adapt": {
        "leadList": "${data}",
        "count": "${count}"
      }
    }
  ],
  "children": [
    {
      "tag": "panel-group",
      "direction": "horizontal",
      "className": "h100",
      "style": {
        "height": "100%"
      },
      "children": [
        {
          "tag": "panel",
          "id": "left_agency_panel",
          "defaultSize": "${Math.round((300/Math.max((window&&window.innerWidth)||1440,1))*100)}",
          "minSize": 16,
          "className": "h100 padding-right10",
          "children": [
            {
              "tag": "layout-fit",
              "className": "h100",
              "title": "旅行社列表",
              "searchToolBar": [
                {
                  "tag": "form",
                  "name": "agency-search-form",
                  "style": {
                    "width": "100%"
                  },
                  "children": [
                    {
                      "tag": "form-item",
                      "name": "search",
                      "label": "旅行社搜索",
                      "style": {
                        "width": "100%",
                        "marginBottom": "8px"
                      },
                      "children": [
                        {
                          "tag": "input",
                          "isSearch": true,
                          "prefixIcon": "SearchOutlined",
                          "enterButton": "搜索",
                          "allowClear": true,
                          "style": {
                            "width": "100%"
                          },
                          "placeholder": "旅行社名称/编码",
                          "onSearchAction": [
                            {
                              "tag": "update-store",
                              "value": {
                                "agencySearchForm.page": 1
                              }
                            },
                            {
                              "tag": "reload-init-action",
                              "group": "agencyList"
                            }
                          ],
                          "action": [
                            {
                              "tag": "update-store",
                              "trigger": "onChange",
                              "value": {
                                "agencySearchForm.search": "${value}",
                                "agencySearchForm.page": 1
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ],
              "bottomToolBar": [
                {
                  "tag": "pagination",
                  "showSizeChanger": true,
                  "align": "end",
                  "pageSize": "${agencySearchForm.size}",
                  "current": "${agencySearchForm.page}",
                  "total": "${agencyCount}",
                  "action": [
                    {
                      "tag": "reload-init-action",
                      "group": "agencyList"
                    }
                  ],
                  "showTotal": true
                }
              ],
              "children": [
                {
                  "tag": "listview",
                  "keyField": "agency_id",
                  "itemData": "${agencyList}",
                  "rowClickAction": [
                    {
                      "tag": "update-store",
                      "value": {
                        "currentAgency": "${row}",
                        "agencySelection": "${[row]}",
                        "selection": [],
                        "searchForm": {
                          "page": 1,
                          "size": "${searchForm.size}",
                          "search": "",
                          "agency_id": "${row.agency_id}",
                          "assign_date_range": []
                        }
                      }
                    },
                    {
                      "tag": "reload-init-action",
                      "group": "leadList"
                    }
                  ],
                  "itemAttr": {
                    "tag": "card",
                    "size": "small",
                    "className": "cursor-pointer",
                    "style": {
                      "display": "block",
                      "width": "100%",
                      "margin": "0 0 6px 0",
                      "borderRadius": "12px",
                      "border": "${currentAgency.agency_id===row.agency_id?'1px solid #1677ff':'1px solid #f0f0f0'}",
                      "boxShadow": "${currentAgency.agency_id===row.agency_id?'0 8px 20px rgba(22,119,255,0.16)':'0 4px 14px rgba(15,23,42,0.08)'}",
                      "background": "${currentAgency.agency_id===row.agency_id?'linear-gradient(135deg,#eef6ff 0%,#ffffff 100%)':'#ffffff'}"
                    },
                    "bodyStyle": {
                      "padding": "11px 12px"
                    },
                    "hoverable": true,
                    "children": [
                      {
                        "tag": "row",
                        "style": {
                          "alignItems": "center"
                        },
                        "children": [
                          {
                            "tag": "col",
                            "span": 4,
                            "style": {
                              "display": "flex",
                              "justifyContent": "center"
                            },
                            "children": [
                              {
                                "tag": "attachment-show",
                                "visible": "${!!row.logo_path}",
                                "path": "${row.logo_path}",
                                "width": 36,
                                "height": 36,
                                "style": {
                                  "borderRadius": "50%",
                                  "overflow": "hidden",
                                  "border": "1px solid #dbeafe"
                                }
                              },
                              {
                                "tag": "div",
                                "visible": "${!row.logo_path}",
                                "style": {
                                  "width": "36px",
                                  "height": "36px",
                                  "borderRadius": "50%",
                                  "display": "flex",
                                  "alignItems": "center",
                                  "justifyContent": "center",
                                  "background": "${currentAgency.agency_id===row.agency_id?'#1677ff':'#e6f4ff'}",
                                  "color": "${currentAgency.agency_id===row.agency_id?'#ffffff':'#1677ff'}",
                                  "fontSize": "14px",
                                  "fontWeight": 700
                                },
                                "children": "${(row.agency_name||'旅').slice(0,1)}"
                              }
                            ]
                          },
                          {
                            "tag": "col",
                            "span": 20,
                            "style": {
                              "minWidth": 0
                            },
                            "children": [
                              {
                                "tag": "row",
                                "style": {
                                  "alignItems": "center",
                                  "gap": "8px",
                                  "marginBottom": "2px"
                                },
                                "children": [
                                  {
                                    "tag": "div",
                                    "style": {
                                      "padding": "1px 8px",
                                      "minWidth": "34px",
                                      "borderRadius": "999px",
                                      "fontSize": "12px",
                                      "fontWeight": 700,
                                      "display": "inline-flex",
                                      "alignItems": "center",
                                      "justifyContent": "center",
                                      "gap": "4px",
                                      "background": "${row.recent_customer_rank==1?'linear-gradient(135deg,#f59e0b 0%,#fbbf24 100%)':row.recent_customer_rank==2?'linear-gradient(135deg,#94a3b8 0%,#cbd5e1 100%)':row.recent_customer_rank==3?'linear-gradient(135deg,#b45309 0%,#d97706 100%)':'#f1f5f9'}",
                                      "color": "${row.recent_customer_rank<=3?'#ffffff':'#475569'}"
                                    },
                                    "children": [
                                      {
                                        "tag": "icon",
                                        "icon": "${row.recent_customer_rank==1?'TrophyFilled':row.recent_customer_rank==2?'CrownFilled':row.recent_customer_rank==3?'FireFilled':'FlagFilled'}",
                                        "style": {
                                          "fontSize": "12px"
                                        }
                                      },
                                      {
                                        "tag": "span",
                                        "children": "${row.recent_customer_rank<=3?row.recent_customer_rank:'#'+row.recent_customer_rank}"
                                      }
                                    ]
                                  },
                                  {
                                    "tag": "div",
                                    "style": {
                                      "fontSize": "14px",
                                      "lineHeight": "22px",
                                      "fontWeight": 600,
                                      "color": "#1f2937",
                                      "whiteSpace": "nowrap",
                                      "overflow": "hidden",
                                      "textOverflow": "ellipsis",
                                      "maxWidth": "180px"
                                    },
                                    "children": "${row.agency_name||'-'}"
                                  }
                                ]
                              },
                              {
                                "tag": "div",
                                "style": {
                                  "fontSize": "13px",
                                  "lineHeight": "20px",
                                  "color": "#6b7280",
                                  "display": "flex",
                                  "alignItems": "center",
                                  "gap": "8px",
                                  "whiteSpace": "nowrap",
                                  "overflow": "hidden",
                                  "textOverflow": "ellipsis"
                                },
                                "children": [
                                  {
                                    "tag": "span",
                                    "style": {
                                      "display": "inline-flex",
                                      "alignItems": "center",
                                      "gap": "4px",
                                      "padding": "2px 8px",
                                      "borderRadius": "999px",
                                      "background": "${currentAgency.agency_id===row.agency_id?'#e0ecff':'#f8fafc'}",
                                      "border": "1px solid ${currentAgency.agency_id===row.agency_id?'#93c5fd':'#e2e8f0'}",
                                      "color": "${currentAgency.agency_id===row.agency_id?'#1d4ed8':'#334155'}",
                                      "fontWeight": 600
                                    }
                                    ,
                                    "children": [
                                      {
                                        "tag": "icon",
                                        "icon": "UsergroupAddOutlined",
                                        "style": {
                                          "fontSize": "12px"
                                        }
                                      },
                                      {
                                        "tag": "span",
                                        "children": "${'最近 ' + (row.recent_customer_count||0)}"
                                      }
                                    ]
                                  },
                                  {
                                    "tag": "span",
                                    "style": {
                                      "display": "inline-flex",
                                      "alignItems": "center",
                                      "gap": "4px"
                                    },
                                    "children": [
                                      {
                                        "tag": "icon",
                                        "icon": "TagOutlined",
                                        "style": {
                                          "fontSize": "12px",
                                          "color": "#64748b"
                                        }
                                      },
                                      {
                                        "tag": "span",
                                        "children": "${row.agency_code||'-'}"
                                      }
                                    ]
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            }
          ]
        },
        {
          "tag": "panel-resize",
          "style": {
            "width": "8px",
            "backgroundColor": "#f2f3f5",
            "cursor": "col-resize"
          }
        },
        {
          "tag": "panel",
          "id": "right_lead_panel",
          "defaultSize": 78,
          "minSize": 60,
          "className": "h100 padding-left10",
          "children": [
            {
              "tag": "layout-fit",
              "className": "h100",
              "title": "${'游客管理与分配 · '+(currentAgency.agency_name||'')}",
              "topRight": [
                {
                  "tag": "button",
                  "type": "primary",
                  "icon": "PlusOutlined",
                  "children": "新增游客",
                  "visible": "${!!currentAgency.agency_id}",
                  "disabled": "${!currentAgency.agency_id}",
                  "action": [
                    { "tag": "update-store", "value": { "leadDialogVisible": true, "leadOp": "add" } },
                    { "tag": "reset-form", "formName": "leadForm" },
                    {
                      "tag": "ajax",
                      "api": "post:/template_data/data?service=hrm.customer_sales_options",
                      "data": {
                        "agency_id": "${currentAgency.agency_id}"
                      },
                      "adapt": {
                        "salesOptions": "${data}",
                        "routeOptions": "${[]}"
                      }
                    },
                    {
                      "tag": "update-form",
                      "formName": "leadForm",
                      "value": {
                        "agency_id": "${currentAgency.agency_id}",
                        "customer_name": "",
                        "contact": "",
                        "wechat_account": "",
                        "source_platform": "douyin",
                        "assign_date": "${searchForm.assign_date_range&&searchForm.assign_date_range.length>1?searchForm.assign_date_range[1]:new Date().toISOString().slice(0,10)}",
                        "sales_user_id": "",
                        "route_id": "",
                        "status": "normal",
                        "description": ""
                      }
                    }
                  ]
                },
                {
                  "tag": "button",
                  "icon": "EditOutlined",
                  "children": "编辑游客",
                  "visible": "${!!currentAgency.agency_id}",
                  "disabled": "${selection.length != 1}",
                  "action": [
                    { "tag": "update-store", "value": { "leadDialogVisible": true, "leadOp": "edit" } },
                    { "tag": "reset-form", "formName": "leadForm" },
                    { "tag": "update-form", "formName": "leadForm", "value": "${selection[0]}" }
                  ]
                },
                {
                  "tag": "button",
                  "icon": "UserSwitchOutlined",
                  "type": "primary",
                  "children": "分配销售",
                  "visible": "${!!currentAgency.agency_id}",
                  "disabled": "${selection.length != 1}",
                  "action": [
                    {
                      "tag": "ajax",
                      "api": "post:/template_data/data?service=hrm.customer_sales_options",
                      "data": {
                        "agency_id": "${selection[0].agency_id}"
                      },
                      "adapt": {
                        "salesOptions": "${data}"
                      }
                    },
                    {
                      "tag": "ajax",
                      "enable": "${!!selection[0].sales_user_id}",
                      "api": "post:/template_data/data?service=hrm.customer_sales_route_options",
                      "data": {
                        "agency_id": "${selection[0].agency_id}",
                        "sales_user_id": "${selection[0].sales_user_id}"
                      },
                      "adapt": {
                        "routeOptions": "${data}"
                      }
                    },
                    {
                      "tag": "update-store",
                      "value": {
                        "assignDialogVisible": true,
                        "assignForm": {
                          "assign_id": "${selection[0].assign_id||''}",
                          "lead_id": "${selection[0].lead_id}",
                          "agency_id": "${selection[0].agency_id}",
                          "assign_date": "${searchForm.assign_date_range&&searchForm.assign_date_range.length>1?searchForm.assign_date_range[1]:new Date().toISOString().slice(0,10)}",
                          "sales_user_id": "${selection[0].sales_user_id||''}",
                          "route_id": "${selection[0].route_id||''}",
                          "supervisor_user_id": "${selection[0].supervisor_user_id||''}",
                          "description": ""
                        }
                      }
                    },
                    {
                      "tag": "reset-form",
                      "formName": "assignForm"
                    },
                    {
                      "tag": "update-form",
                      "formName": "assignForm",
                      "value": "${assignForm}"
                    }
                  ]
                },
                {
                  "tag": "button",
                  "icon": "DeleteOutlined",
                  "danger": true,
                  "children": "删除游客",
                  "visible": "${!!currentAgency.agency_id}",
                  "disabled": "${selection.length<=0}",
                  "confirm": {
                    "title": "确认删除吗？",
                    "description": "${'确认删除'+selection.length+'条游客记录吗？'}"
                  },
                  "action": [
                    {
                      "tag": "ajax",
                      "api": "post:/template_data/data?service=hrm.customer_lead_delete",
                      "data": { "lead_id_list": "${selection.map(item=>item.lead_id)}" }
                    },
                    {
                      "tag": "reload-init-action",
                      "group": "leadList"
                    }
                  ]
                }
              ],
              "searchToolBar": [
                {
                  "tag": "form",
                  "name": "lead-search-form",
                  "initialValues": "${searchForm}",
                  "visible": "${!!currentAgency.agency_id}",
                  "style": { "width": "100%" },
                  "children": [
                    {
                      "tag": "row",
                      "children": [
                        {
                          "tag": "col",
                          "span": 10,
                          "children": [
                            {
                              "tag": "form-item",
                              "name": "assign_date_range",
                              "label": "分配日期",
                              "children": [
                                {
                                  "tag": "date",
                                  "range": true,
                                  "valueFormat": "YYYY-MM-DD",
                                  "action": [
                                    {
                                      "tag": "update-store",
                                      "trigger": "onChange",
                                      "value": {
                                        "searchForm.assign_date_range": "${value&&value.length===2&&value[0]&&value[1]?value:[]}",
                                        "searchForm.page": 1
                                      }
                                    },
                                    {
                                      "tag": "reload-init-action",
                                      "trigger": "onChange",
                                      "group": "leadList"
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "tag": "col",
                          "span": 14,
                          "children": [
                            {
                              "tag": "form-item",
                              "name": "search",
                              "label": "游客搜索",
                              "children": [
                                {
                                  "tag": "input",
                                  "isSearch": true,
                                  "enterButton": "搜索",
                                  "prefixIcon": "SearchOutlined",
                                  "allowClear": true,
                                  "placeholder": "游客姓名/联系方式/微信号",
                                  "onSearchAction": [
                                    {
                                      "tag": "update-store",
                                      "value": {
                                        "searchForm.page": 1
                                      }
                                    },
                                    {
                                      "tag": "reload-init-action",
                                      "group": "leadList"
                                    }
                                  ],
                                  "action": [
                                    {
                                      "tag": "update-store",
                                      "trigger": "onChange",
                                      "value": {
                                        "searchForm.search": "${value}",
                                        "searchForm.page": 1
                                      }
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ],
              "bottomToolBar": [
                {
                  "tag": "pagination",
                  "visible": "${!!currentAgency.agency_id}",
                  "showSizeChanger": true,
                  "align": "end",
                  "pageSize": "${searchForm.size}",
                  "current": "${searchForm.page}",
                  "total": "${count}",
                  "action": [
                    {
                      "tag": "reload-init-action",
                      "group": "leadList"
                    }
                  ],
                  "showTotal": true
                }
              ],
              "children": [
                {
                  "tag": "table",
                  "selection": "${selection}",
                  "rowSelection": "multiple",
                  "columnDefs": [
                    {
                      "headerName": "#",
                      "width": 60,
                      "valueGetter": "node.rowIndex + 1",
                      "sortable": false,
                      "pinned": "left"
                    },
                    {
                      "pinned": "left",
                      "checkboxSelection": true,
                      "headerCheckboxSelection": true,
                      "headerName": "游客姓名",
                      "field": "customer_name"
                    },
                    {
                      "headerName": "联系方式",
                      "field": "contact"
                    },
                    {
                      "headerName": "微信号",
                      "field": "wechat_account"
                    },
                    {
                      "headerName": "来源",
                      "field": "source_platform",
                      "valueFormatter": "${value==='xiaohongshu'?'小红书':'抖音'}"
                    },
                    {
                      "headerName": "旅行社",
                      "field": "agency_name"
                    },
                    {
                      "headerName": "销售",
                      "field": "sales_nick",
                      "valueFormatter": "${value||'未分配'}"
                    },
                    {
                      "headerName": "旅游线路",
                      "field": "route_name",
                      "valueFormatter": "${value||'-'}"
                    },
                    {
                      "headerName": "分配日期",
                      "field": "assign_date"
                    },
                    {
                      "headerName": "创建时间",
                      "field": "create_time"
                    }
                  ],
                  "rowData": "${leadList}",
                  "action": [
                    {
                      "tag": "update-store",
                      "trigger": "onSelectionChanged",
                      "value": {
                        "selection": "${selection}"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "tag": "dialog",
      "title": "${leadOp=='add'?'新增游客':'编辑游客'}",
      "width": "48%",
      "open": "${leadDialogVisible}",
      "action": [
        {
          "tag": "submit-form",
          "formName": "leadForm"
        },
        {
          "tag": "ajax",
          "enable": "${leadOp=='add'}",
          "api": "post:/template_data/data?service=hrm.customer_lead_save_with_assign",
          "appendFormFields": "leadForm"
        },
        {
          "tag": "ajax",
          "enable": "${leadOp=='edit'}",
          "api": "post:/template_data/data?service=hrm.customer_lead_update",
          "appendFormFields": "leadForm",
          "data": {
            "lead_id": "${selection[0].lead_id}"
          }
        },
        {
          "tag": "update-store",
          "value": {
            "leadDialogVisible": false
          }
        },
        {
          "tag": "reload-init-action",
          "group": "leadList"
        }
      ],
      "children": [
        {
          "tag": "form",
          "name": "leadForm",
          "initialValues": "${leadForm}",
          "labelCol": {
            "span": 5
          },
          "children": [
            {
              "tag": "form-item",
              "name": "agency_id",
              "label": "旅行社",
              "rules": [{ "required": true, "message": "请选择旅行社" }],
              "children": [
                {
                  "tag": "select",
                  "fieldNames": {
                    "label": "agency_name",
                    "value": "agency_id"
                  },
                  "options": "${agencyList}"
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "customer_name",
              "label": "游客姓名",
              "rules": [{ "required": true, "message": "请输入游客姓名" }],
              "children": [{ "tag": "input", "placeholder": "如：王五" }]
            },
            {
              "tag": "form-item",
              "name": "contact",
              "label": "联系方式",
              "children": [{ "tag": "input", "placeholder": "手机号/微信手机号" }]
            },
            {
              "tag": "form-item",
              "name": "wechat_account",
              "label": "微信号",
              "children": [{ "tag": "input", "placeholder": "待添加微信账号" }]
            },
            {
              "tag": "form-item",
              "name": "source_platform",
              "label": "来源平台",
              "children": [
                {
                  "tag": "select",
                  "options": [
                    { "value": "douyin", "label": "抖音" },
                    { "value": "xiaohongshu", "label": "小红书" }
                  ]
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "assign_date",
              "label": "分配日期",
              "visible": "${leadOp=='add'}",
              "children": [{ "tag": "date", "valueFormat": "YYYY-MM-DD" }]
            },
            {
              "tag": "form-item",
              "name": "sales_user_id",
              "label": "销售",
              "visible": "${leadOp=='add'}",
              "children": [
                {
                  "tag": "select",
                  "allowClear": true,
                  "options": "${salesOptions}",
                  "action": [
                    {
                      "tag": "ajax",
                      "trigger": "onChange",
                      "enable": "${!!value}",
                      "api": "post:/template_data/data?service=hrm.customer_sales_route_options",
                      "data": {
                        "agency_id": "${getFormValue('leadForm','agency_id')}",
                        "sales_user_id": "${value}"
                      },
                      "adapt": {
                        "routeOptions": "${data}"
                      }
                    },
                    {
                      "tag": "update-form",
                      "trigger": "onChange",
                      "formName": "leadForm",
                      "value": {
                        "route_id": ""
                      }
                    },
                    {
                      "tag": "update-store",
                      "trigger": "onChange",
                      "enable": "${!value}",
                      "value": {
                        "routeOptions": []
                      }
                    }
                  ]
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "route_id",
              "label": "线路",
              "visible": "${leadOp=='add'}",
              "children": [{ "tag": "select", "allowClear": true, "options": "${routeOptions}" }]
            },
            {
              "tag": "form-item",
              "name": "description",
              "label": "备注",
              "children": [
                { "tag": "input", "isTextarea": true, "rows": 3, "placeholder": "备注信息" }
              ]
            }
          ]
        }
      ]
    },
    {
      "tag": "dialog",
      "title": "分配销售",
      "width": "42%",
      "open": "${assignDialogVisible}",
      "action": [
        {
          "tag": "submit-form",
          "formName": "assignForm"
        },
        {
          "tag": "ajax",
          "enable": "${!getFormValue('assignForm','assign_id')}",
          "api": "post:/template_data/data?service=hrm.customer_lead_assign_save",
          "appendFormFields": "assignForm"
        },
        {
          "tag": "ajax",
          "enable": "${!!getFormValue('assignForm','assign_id')}",
          "api": "post:/template_data/data?service=hrm.customer_lead_assign_update",
          "appendFormFields": "assignForm"
        },
        {
          "tag": "update-store",
          "value": {
            "assignDialogVisible": false
          }
        },
        {
          "tag": "reload-init-action",
          "group": "leadList"
        }
      ],
      "children": [
        {
          "tag": "form",
          "name": "assignForm",
          "initialValues": "${assignForm}",
          "labelCol": {
            "span": 6
          },
          "children": [
            {
              "tag": "form-item",
              "label": "游客",
              "children": [
                { "tag": "div", "children": "${selection.length>0?selection[0].customer_name:'-'}" }
              ]
            },
            {
              "tag": "form-item",
              "name": "assign_date",
              "label": "分配日期",
              "rules": [{ "required": true, "message": "请选择分配日期" }],
              "children": [{ "tag": "date", "valueFormat": "YYYY-MM-DD" }]
            },
            {
              "tag": "form-item",
              "name": "sales_user_id",
              "label": "分配给销售",
              "rules": [{ "required": true, "message": "请选择销售" }],
              "children": [
                {
                  "tag": "select",
                  "options": "${salesOptions}",
                  "action": [
                    {
                      "tag": "ajax",
                      "api": "post:/template_data/data?service=hrm.customer_sales_route_options",
                      "data": {
                        "agency_id": "${getFormValue('assignForm','agency_id')}",
                        "sales_user_id": "${value}"
                      },
                      "adapt": {
                        "routeOptions": "${data}"
                      }
                    },
                    {
                      "tag": "update-form",
                      "formName": "assignForm",
                      "value": {
                        "route_id": ""
                      }
                    }
                  ]
                }
              ]
            },
            {
              "tag": "form-item",
              "name": "route_id",
              "label": "旅游线路",
              "rules": [{ "required": true, "message": "请选择旅游线路" }],
              "children": [{ "tag": "select", "options": "${routeOptions}" }]
            },
            {
              "tag": "form-item",
              "name": "description",
              "label": "备注",
              "children": [
                { "tag": "input", "isTextarea": true, "rows": 3, "placeholder": "分配说明" }
              ]
            }
          ]
        }
      ]
    }
  ]
}
